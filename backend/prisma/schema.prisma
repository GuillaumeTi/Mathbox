// MathBox SaaS - Prisma Schema
// Strict Relational integrity for Prof <-> Course <-> Student <-> Documents

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum Role {
  PROFESSOR
  PARENT
  STUDENT
}

enum CourseStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum SessionStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum DocumentType {
  EXERCISE
  NOTES
  SCREENSHOT
  REPORT
  RECORDING
  OTHER
}

enum CreditType {
  PURCHASE
  SPEND
  REFUND
}

enum Recurrence {
  ONCE
  WEEKLY
  BIWEEKLY
}

enum InvoiceStatus {
  PAID
  PENDING
  CANCELLED
}

enum InvoiceType {
  INVOICE
  RECEIPT
  CREDIT_NOTE
  PLATFORM_INVOICE
  ACOMPTE
}

enum BillingPreference {
  PER_CLASS
  MONTHLY
}

enum TransactionType {
  SUBSCRIPTION
  AI_CREDITS
  COMMISSION
}

enum TransactionStatus {
  PENDING
  INVOICED
}

enum LegalStatus {
  PRO
  INDIVIDUAL
}

enum TvaStatus {
  FRANCHISE
  EXONERATED
  SUBJECT_20
}

// ============ MODELS ============

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  username  String?  @unique
  password  String
  name      String
  role      Role     @default(STUDENT)
  avatarUrl String?
  subjects  String[] @default([])

  // Family relation (Parent -> Children)
  parentId String?
  parent   User?   @relation("FamilyTree", fields: [parentId], references: [id])
  children User[]  @relation("FamilyTree")

  // Address (for billing)
  street  String?
  city    String?
  zipCode String?
  address  String?
  phone    String?

  // Professional / Billing Status
  legalStatus    LegalStatus?
  tvaStatus      TvaStatus?
  siret          String?
  companyName    String?
  commissionRate Float        @default(0.10)
  billingMandate Boolean      @default(false) // "Mandat de facturation" agreement

  // Storage quota (bytes used, max 10GB)
  storageUsed    Float        @default(0)

  // Magic link first-login
  needsPasswordSetup Boolean @default(false)

  // Billing
  credits            Int     @default(0)
  stripeCustomerId   String?
  subscriptionStatus String? // ACTIVE, INACTIVE, TRIAL, EXPIRED

  // Stripe Connect (for Professors receiving marketplace payments)
  stripeAccountId      String?
  stripeSubscriptionId String?

  // Trial tracking
  trialStartDate DateTime?
  trialEndDate   DateTime?

  // Weekly video limiter (minutes accumulated, resets every Monday)
  weeklyVideoMinutes Int       @default(0)
  weeklyVideoResetAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  coursesAsProf    Course[]    @relation("ProfCourses")
  coursesAsStudent Course[]    @relation("StudentCourses")
  documents        Document[]
  folders          Folder[]
  aiCredits        AICredit[]
  homeworks        Homework[]  @relation("StudentHomeworks")
  invoices         Invoice[]
  sentCourseInvoices     CourseInvoice[] @relation("ProfInvoices")
  receivedCourseInvoices CourseInvoice[] @relation("ParentInvoices")
  studentStocksAsStudent StudentStock[]  @relation("StudentStocks")
  studentStocksAsProf    StudentStock[]  @relation("ProfStocks")
  platformTransactions   PlatformTransaction[]
}

model Course {
  id          String       @id @default(uuid())
  code        String       @unique // e.g. PHY-9921
  title       String
  subject     String?
  level       String?
  description String?

  // Scheduling
  recurrence  Recurrence   @default(ONCE)
  dayOfWeek   Int?         // 0=Sun, 1=Mon, ..., 6=Sat
  startTime   String?      // "14:00" format for recurring
  startDate   DateTime?    // Exact date for one-time
  duration    Int          @default(60) // minutes
  status             CourseStatus      @default(SCHEDULED)
  billingPreference  BillingPreference @default(PER_CLASS)

  // Whiteboard persistent state
  whiteboardState Json?  // [{id, title, canvasData, background}]

  // Relations
  professorId String
  professor   User     @relation("ProfCourses", fields: [professorId], references: [id])
  studentId   String?
  student     User?    @relation("StudentCourses", fields: [studentId], references: [id])

  sessions       Session[]
  documents      Document[]
  homeworks      Homework[]
  folders        Folder[]
  courseInvoices CourseInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id           String        @id @default(uuid())
  date         DateTime      @default(now())
  status       SessionStatus @default(SCHEDULED)
  recordingUrl String?
  aiReportUrl  String?
  notes        String?

  // Relations
  courseId String
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  documents Document[]
  folder    Folder?    @relation("SessionFolder")

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Document {
  id       String       @id @default(uuid())
  title    String
  type     DocumentType @default(OTHER)
  url      String       // local path or S3 URL
  s3Key    String?      // Scaleway/S3 object key (future migration)
  size     Int?         // bytes
  mimeType String?

  // Relations
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  courseId   String?
  course     Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  sessionId  String?
  session    Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  folderId   String?
  folder     Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model Folder {
  id              String  @id @default(uuid())
  name            String
  path            String  // Virtual path e.g. "/students/uuid/2026-02-14"
  isAutoGenerated Boolean @default(false)

  // Relations
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  parentId String?
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderTree")

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  sessionId String?  @unique
  session   Session? @relation("SessionFolder", fields: [sessionId], references: [id], onDelete: SetNull)

  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AICredit {
  id          String     @id @default(uuid())
  amount      Int
  type        CreditType
  description String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Homework {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean  @default(false)

  courseId String
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation("StudentHomeworks", fields: [studentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id          String        @id @default(uuid())
  amount      Float
  status      InvoiceStatus @default(PENDING)
  description String?
  fileUrl     String?       // PDF link

  // Linked to Parent user
  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CourseInvoice {
  id            String        @id @default(uuid())
  invoiceNumber String?       @unique
  amount        Float
  hours       Float?
  hourlyRate  Float?
  discount    Float?        @default(0)
  status      InvoiceStatus @default(PENDING)
  description String?
  documentUrl String?
  type        InvoiceType?

  // Relations
  courseId    String
  course     Course @relation(fields: [courseId], references: [id])
  professorId String
  professor  User   @relation("ProfInvoices", fields: [professorId], references: [id])
  parentId   String
  parent     User   @relation("ParentInvoices", fields: [parentId], references: [id])

  // Stripe
  stripePaymentIntentId String?

  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ STUDENT STOCK (Hour Tracking) ============

model StudentStock {
  id                     String @id @default(uuid())
  purchasedHours         Float  @default(0)
  consumedHoursThisMonth Float  @default(0)

  studentId String
  student   User   @relation("StudentStocks", fields: [studentId], references: [id])
  profId    String
  prof      User   @relation("ProfStocks", fields: [profId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, profId])
}

// ============ PLATFORM TRANSACTIONS (B2B) ============

model PlatformTransaction {
  id     String            @id @default(uuid())
  type   TransactionType
  amount Float
  status TransactionStatus @default(PENDING)

  profId String
  prof   User   @relation(fields: [profId], references: [id])

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
